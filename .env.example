# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False

# Comma-separated, must include your API domain and any other trusted hosts
ALLOWED_HOSTS=api.yourdomain.com

# Comma-separated HTTPS origins allowed to make CSRF-protected requests
CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com,https://your-frontend.vercel.app

# Comma-separated frontend origins allowed by CORS
FRONTEND_ORIGINS=https://your-frontend.vercel.app

# ── Caddy / TLS ───────────────────────────────────────────────────────────────
DOMAIN=api.yourdomain.com
LETSENCRYPT_EMAIL=you@yourdomain.com

# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# Leave blank to use SQLite (local dev only)
SUPABASE_DB_HOST=
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_PORT=5432
